# Default: auto-detect text files, normalize to LF on commit
* text=auto eol=lf

# Text files — explicit for clarity
*.html   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.svg    text eol=lf
*.txt    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# Binary assets — never modified by git
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
